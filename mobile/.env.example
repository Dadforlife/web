# URL de l'API Next.js (cette API lit/écrit les données dans la BDD Neon).
# Optionnel : si défini à la racine dans .env.local, l'app.config.js le charge automatiquement.
# Sinon, créez mobile/.env avec cette variable.
# Simulateur : http://localhost:3000  |  Appareil réel : http://VOTRE_IP:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
