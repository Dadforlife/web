# Neon PostgreSQL (obligatoire) — utilisée par l'API Next.js ; l'app mobile consomme cette API.
DATABASE_URL="postgresql://neondb_owner:xxx@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js secret (générer avec: openssl rand -base64 32)
AUTH_SECRET="votre_secret_ici"

# URL de l'app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postmark (envoi d'emails)
POSTMARK_API_TOKEN=your_postmark_server_token
EMAIL_FROM="Dad for Life <notifications@dadforlife.org>"

# App mobile : URL de l'API Next.js (cette API lit les données depuis Neon).
# Simulateur : http://localhost:3000  |  Appareil réel : http://VOTRE_IP:3000
EXPO_PUBLIC_API_URL=http://localhost:3000